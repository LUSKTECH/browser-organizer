{
  "manifest_version": 3,
  "name": "Browser Organizer",
  "version": "0.1.0",
  "description": "Uses your local Claude CLI to group tabs, close forgotten ones, and tidy bookmarks. All processing stays on your machine.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "history",
    "storage",
    "alarms",
    "sidePanel",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {},
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
